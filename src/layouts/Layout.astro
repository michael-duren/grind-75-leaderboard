---
import '../styles/global.css';
import { SITE, ISSUES_URL } from '../lib/site';

interface Props {
  title?: string;
}

const { title = 'Grind 75 Leaderboard' } = Astro.props;
const user = Astro.locals.user;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Race your friends through the Grind 75 problem set." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {/* Apply the saved/system theme before paint to avoid a flash. */}
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        document.documentElement.dataset.theme = saved || (prefersLight ? 'light' : 'dark');
      })();
    </script>
  </head>
  <body>
    <header class="border-b border-border bg-surface/60 backdrop-blur">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4">
        <a href="/" class="group flex items-center gap-2 no-underline">
          <span class="text-phosphor">▲</span>
          <span
            class="font-mono text-lg font-bold tracking-tight text-ink group-hover:text-phosphor"
          >
            grind<span class="text-gold">75</span>
          </span>
        </a>
        <div class="flex items-center gap-5 font-mono text-sm">
          <a href="/">leaderboard</a>
          <a href="/about">about</a>
          {
            user ? (
              <>
                <a href="/dashboard">my progress</a>
                <a href="/settings">settings</a>
                <span class="text-muted">@{user.username}</span>
                <form method="POST" action="/api/logout" class="inline">
                  <button
                    type="submit"
                    class="cursor-pointer border-none bg-transparent p-0 font-mono text-sm text-muted hover:text-hard"
                  >
                    logout
                  </button>
                </form>
              </>
            ) : (
              <>
                <a href="/login">login</a>
                <a
                  href="/register"
                  class="rounded border border-phosphor/40 px-3 py-1 text-phosphor hover:bg-phosphor/10"
                >
                  sign up
                </a>
              </>
            )
          }
          <button
            id="theme-toggle"
            type="button"
            aria-label="Toggle light/dark theme"
            title="Toggle theme"
            class="cursor-pointer border-none bg-transparent p-0 text-base leading-none text-muted hover:text-phosphor"
          >
            <span class="icon-sun">☀</span>
            <span class="icon-moon">☾</span>
          </button>
        </div>
      </nav>
    </header>

    <main class="mx-auto max-w-5xl px-5 py-8">
      <slot />
    </main>

    <footer class="mt-12 border-t border-border">
      <div
        class="mx-auto flex max-w-5xl flex-col gap-6 px-5 py-8 font-mono text-sm sm:flex-row sm:justify-between"
      >
        <div>
          <p class="text-ink">
            grind<span class="text-gold">75</span> leaderboard
          </p>
          <p class="mt-1 text-xs text-muted">
            // first to clear all 168 problems takes the crown. proof required.
          </p>
          <p class="mt-3 text-xs text-muted">
            built by <a href={SITE.website} target="_blank" rel="noopener noreferrer"
              >{SITE.author}</a
            >
          </p>
        </div>

        <div class="flex flex-col gap-4 sm:flex-row sm:gap-12">
          <div>
            <p class="text-xs uppercase tracking-wider text-muted">Connect</p>
            <ul class="mt-2 space-y-1">
              <li>
                <a href={SITE.github} target="_blank" rel="noopener noreferrer">GitHub</a>
              </li>
              <li>
                <a href={SITE.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
              </li>
              <li>
                <a href={SITE.website} target="_blank" rel="noopener noreferrer">Website</a>
              </li>
            </ul>
          </div>

          <div>
            <p class="text-xs uppercase tracking-wider text-muted">Found a bug?</p>
            <ul class="mt-2 space-y-1">
              <li>
                <a href={ISSUES_URL} target="_blank" rel="noopener noreferrer">Submit an issue →</a>
              </li>
              <li>
                <a href={SITE.repo} target="_blank" rel="noopener noreferrer">Source code</a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </footer>

    <script>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const root = document.documentElement;
        const next = root.dataset.theme === 'light' ? 'dark' : 'light';
        root.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>
  </body>
</html>
