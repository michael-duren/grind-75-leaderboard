---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Grind 75 Leaderboard' } = Astro.props;
const user = Astro.locals.user;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Race your friends through the Grind 75 problem set." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="border-b border-border bg-surface/60 backdrop-blur">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4">
        <a href="/" class="group flex items-center gap-2 no-underline">
          <span class="text-phosphor">▲</span>
          <span
            class="font-mono text-lg font-bold tracking-tight text-ink group-hover:text-phosphor"
          >
            grind<span class="text-gold">75</span>
          </span>
        </a>
        <div class="flex items-center gap-5 font-mono text-sm">
          <a href="/">leaderboard</a>
          {
            user ? (
              <>
                <a href="/dashboard">my progress</a>
                <span class="text-muted">@{user.username}</span>
                <form method="POST" action="/api/logout" class="inline">
                  <button
                    type="submit"
                    class="cursor-pointer border-none bg-transparent p-0 font-mono text-sm text-muted hover:text-hard"
                  >
                    logout
                  </button>
                </form>
              </>
            ) : (
              <>
                <a href="/login">login</a>
                <a
                  href="/register"
                  class="rounded border border-phosphor/40 px-3 py-1 text-phosphor hover:bg-phosphor/10"
                >
                  sign up
                </a>
              </>
            )
          }
        </div>
      </nav>
    </header>

    <main class="mx-auto max-w-5xl px-5 py-8">
      <slot />
    </main>

    <footer class="mx-auto max-w-5xl px-5 py-10 font-mono text-xs text-muted">
      <p>// first to clear all 168 problems takes the crown. proof required.</p>
    </footer>
  </body>
</html>
