---
import Layout from '../layouts/Layout.astro';
import ProblemGrid from '../components/ProblemGrid.tsx';
import ConsistencyPanel from '../components/ConsistencyPanel.tsx';
import { getLeaderboard, getProblemsForUser } from '../lib/queries';

export const prerender = false;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login');
}

const [problems, { totalPoints }] = await Promise.all([
  getProblemsForUser(user.id),
  getLeaderboard(),
]);

// Metrics inputs — derived here so "now" is fixed once on the server (avoids an
// SSR/hydration mismatch in the client:load panel). Activity = every logged
// submission; a solve's date is its most recent proof.
const now = Date.now();
const activity = problems
  .flatMap((p) => p.submissions.map((s) => Date.parse(s.createdAt)))
  .filter((t) => Number.isFinite(t));
const solves = problems
  .filter((p) => p.solved)
  .map((p) => ({
    lastSolvedAt: p.submissions.length
      ? Math.max(...p.submissions.map((s) => Date.parse(s.createdAt)))
      : now,
  }));
---

<Layout title="My Progress">
  <section class="mb-2">
    <h1 class="font-mono text-2xl font-bold text-ink">My Progress</h1>
    <p class="mt-1 text-sm text-muted">
      Solve a problem, paste the submission link as proof, mark it done. Peeked at the answer? Flag
      it ★ and find it again under the review tab.
    </p>
  </section>

  <ConsistencyPanel
    client:load
    activity={activity}
    solves={solves}
    totalProblems={problems.length}
    now={now}
  />

  <ProblemGrid client:load problems={problems} totalPoints={totalPoints} />
</Layout>
