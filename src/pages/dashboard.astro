---
import Layout from '../layouts/Layout.astro';
import ProblemGrid from '../components/ProblemGrid.tsx';
import ConsistencyPanel from '../components/ConsistencyPanel.tsx';
import { getProblemsForUser, getUserSettings } from '../lib/queries';
import { computePace, selectPlan } from '../lib/schedule';
import { planRank } from '../lib/grind75-order';

export const prerender = false;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login');
}

const [problems, settings] = await Promise.all([
  getProblemsForUser(user.id),
  getUserSettings(user.id),
]);

// The plan is the problems that fit your time budget, in priority order — the
// least-essential ones are trimmed first. With no saved plan yet, show
// everything (still priority-ordered) and prompt the user to set one up.
const ordered = [...problems].sort((a, b) => planRank(a.slug) - planRank(b.slug));
const shown = settings ? selectPlan(ordered, settings) : ordered;
const scopePoints = shown.reduce((sum, p) => sum + p.points, 0);

// Pace target, derived from the plan + how far through it we are. "now" is fixed
// once on the server so the numbers match what the (server-rendered) banner shows.
const now = Date.now();
const pace =
  settings && shown.length
    ? computePace({
        weeks: settings.weeks,
        hoursPerWeek: settings.hoursPerWeek,
        startedAt: Date.parse(settings.startedAt),
        now,
        totalInScope: shown.length,
        pointsInScope: scopePoints,
        workloadMinutes: shown.reduce((sum, p) => sum + p.minutes, 0),
        solvedInScope: shown.filter((p) => p.solved).length,
      })
    : null;

const deadlineLabel = pace
  ? new Date(pace.deadline).toLocaleDateString(undefined, {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
    })
  : null;

// Metrics inputs — derived here so "now" is fixed once on the server (avoids an
// SSR/hydration mismatch in the client:load panel). Readiness spans every
// problem, so these use the full list, not the difficulty-scoped one.
const activity = problems
  .flatMap((p) => p.submissions.map((s) => Date.parse(s.createdAt)))
  .filter((t) => Number.isFinite(t));
const solves = problems
  .filter((p) => p.solved)
  .map((p) => ({
    lastSolvedAt: p.submissions.length
      ? Math.max(...p.submissions.map((s) => Date.parse(s.createdAt)))
      : now,
  }));
---

<Layout title="My Progress">
  <section class="mb-2 flex items-start justify-between gap-4">
    <div>
      <h1 class="font-mono text-2xl font-bold text-ink">My Progress</h1>
      <p class="mt-1 text-sm text-muted">
        Solve a problem, paste the submission link as proof, mark it done. Peeked at the answer?
        Flag it ★ and find it again under the review tab.
      </p>
    </div>
    <a
      href="/settings"
      class="shrink-0 rounded border border-border px-3 py-1.5 font-mono text-xs text-muted hover:border-phosphor hover:text-phosphor"
    >
      ⚙ plan
    </a>
  </section>

  {
    pace ? (
      <section class="mb-6 rounded-lg border border-border bg-surface/40 p-4 font-mono text-xs">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <span class="text-muted">
            {settings!.weeks}-week plan · {settings!.hoursPerWeek}h/week ·{' '}
            <span class="text-ink">{pace.budgetedHours}h budgeted</span>
          </span>
          <span class={pace.overdue ? 'text-hard' : 'text-muted'}>
            {pace.overdue
              ? `overdue · was due ${deadlineLabel}`
              : `due ${deadlineLabel} · ${pace.daysRemaining}d left`}
          </span>
        </div>
        <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1">
          <span class="text-muted">
            target by today:{' '}
            <span class="text-ink tabular">
              {pace.targetSolved}/{shown.length}
            </span>{' '}
            solved
          </span>
          {pace.onTrack ? (
            <span class="text-phosphor">✓ on track</span>
          ) : (
            <span class="text-gold">behind by {pace.problemsBehind}</span>
          )}
        </div>
      </section>
    ) : (
      <section class="mb-6 rounded-lg border border-border bg-surface/40 p-4 font-mono text-xs text-muted">
        No study plan yet.{' '}
        <a href="/settings" class="text-phosphor">
          Set a schedule
        </a>{' '}
        to track your pace and pick which difficulties to show.
      </section>
    )
  }

  <ConsistencyPanel
    client:load
    activity={activity}
    solves={solves}
    totalProblems={problems.length}
    now={now}
  />

  <ProblemGrid client:load problems={shown} totalPoints={scopePoints} />
</Layout>
