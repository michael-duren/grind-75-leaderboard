---
import Layout from '../layouts/Layout.astro';
import { ISSUES_URL } from '../lib/site';

export const prerender = false;

const user = Astro.locals.user;

const steps = [
  {
    n: 1,
    title: 'Create an account',
    body: 'Pick a username and password, and add your LeetCode handle so others can find your profile.',
  },
  {
    n: 2,
    title: 'Solve a Grind 75 problem',
    body: 'Work through any of the 168 problems on LeetCode. Order does not matter — solve whatever you like.',
  },
  {
    n: 3,
    title: 'Submit proof',
    body: 'On the LeetCode submission page, copy the URL (it looks like leetcode.com/problems/two-sum/submissions/123…) and paste it next to the problem on your dashboard.',
  },
  {
    n: 4,
    title: 'Mark it solved',
    body: 'Hit “mark solved.” Your points update instantly and you climb the leaderboard.',
  },
];
---

<Layout title="About">
  <section class="mb-10 max-w-2xl">
    <h1 class="font-mono text-3xl font-bold text-ink">How it works</h1>
    <p class="mt-3 text-muted">
      A friendly race through the <strong class="text-ink">Grind 75</strong> problem set (168 problems).
      Everyone tracks their progress here, proves each solve with a submission link, and competes for
      the top of the leaderboard. First to finish all 168 wins; everyone after races for second.
    </p>
  </section>

  <section class="mb-12">
    <h2 class="mb-4 font-mono text-xl font-bold text-phosphor">Getting started</h2>
    <ol class="grid gap-4 sm:grid-cols-2">
      {
        steps.map((s) => (
          <li class="rounded-lg border border-border bg-surface/40 p-4">
            <div class="flex items-center gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-phosphor/40 font-mono text-sm text-phosphor">
                {s.n}
              </span>
              <h3 class="font-mono font-semibold text-ink">{s.title}</h3>
            </div>
            <p class="mt-2 text-sm text-muted">{s.body}</p>
          </li>
        ))
      }
    </ol>
    {
      !user && (
        <a
          href="/register"
          class="mt-6 inline-block rounded border border-phosphor/50 bg-phosphor/10 px-4 py-2 font-mono text-phosphor hover:bg-phosphor/20"
        >
          Create your account →
        </a>
      )
    }
  </section>

  <section class="mb-12 max-w-2xl">
    <h2 class="mb-4 font-mono text-xl font-bold text-phosphor">Scoring</h2>
    <p class="text-muted">
      Each problem is worth <code class="text-ink">minutes × difficulty</code>, rewarding both
      effort and skill:
    </p>
    <div class="mt-4 overflow-hidden rounded-lg border border-border">
      <table class="w-full text-left font-mono text-sm">
        <thead>
          <tr class="border-b border-border text-xs uppercase tracking-wider text-muted">
            <th class="px-4 py-2">Difficulty</th>
            <th class="px-4 py-2">Multiplier</th>
            <th class="px-4 py-2">Example</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-border/60">
            <td class="px-4 py-2 text-easy">Easy</td>
            <td class="px-4 py-2">×1</td>
            <td class="px-4 py-2 text-muted">15 min → 15 pts</td>
          </tr>
          <tr class="border-b border-border/60">
            <td class="px-4 py-2 text-medium">Medium</td>
            <td class="px-4 py-2">×2</td>
            <td class="px-4 py-2 text-muted">30 min → 60 pts</td>
          </tr>
          <tr>
            <td class="px-4 py-2 text-hard">Hard</td>
            <td class="px-4 py-2">×3</td>
            <td class="px-4 py-2 text-muted">40 min → 120 pts</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="mt-4 text-sm text-muted">
      Clear all 168 and you bank the full <span class="text-gold">9,275 points</span>.
    </p>
  </section>

  <section class="mb-12 max-w-2xl">
    <h2 class="mb-4 font-mono text-xl font-bold text-phosphor">Ranking</h2>
    <ul class="space-y-2 text-muted">
      <li>
        🏁 <strong class="text-ink">Finishers first.</strong> Anyone who has solved every problem sits
        at the top, ordered by who finished earliest.
      </li>
      <li>
        📈 <strong class="text-ink">Then by points.</strong> Everyone else is ranked by total points,
        breaking ties by problems solved.
      </li>
      <li>
        🔗 <strong class="text-ink">Proof required.</strong> A solve only counts with a valid LeetCode
        submission link — click any player to see their proof.
      </li>
    </ul>
  </section>

  <section class="max-w-2xl">
    <h2 class="mb-3 font-mono text-xl font-bold text-phosphor">Something broken?</h2>
    <p class="text-muted">
      Found a bug or have an idea?
      <a href={ISSUES_URL} target="_blank" rel="noopener noreferrer">Open an issue on GitHub</a> — links
      are in the footer too.
    </p>
  </section>
</Layout>
