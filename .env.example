# You normally do NOT need this file: Netlify DB injects NETLIFY_DATABASE_URL
# automatically under `netlify dev` and in production.
#
# Only set this to point the app at an external Postgres (e.g. for a standalone
# script or a non-Netlify environment). Copy to `.env` if you need it.
# NETLIFY_DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
